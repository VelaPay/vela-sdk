{
  "name": "@velapay/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Vela subscription billing protocol on Solana",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vela-labs/vela-sdk.git"
  },
  "homepage": "https://velapay.com",
  "bugs": {
    "url": "https://github.com/vela-labs/vela-sdk/issues"
  },
  "keywords": [
    "solana",
    "subscription",
    "billing",
    "payments",
    "recurring",
    "web3",
    "blockchain",
    "token-2022",
    "transfer-hook",
    "vela"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/cjs/src/index.cjs",
  "module": "./dist/esm/src/index.js",
  "types": "./dist/esm/src/index.d.ts",
  "typesVersions": {
    "*": {
      "browser": ["./dist/esm/src/browser/index.d.ts"],
      "events": ["./dist/esm/src/events/index.d.ts"],
      "x402": ["./dist/esm/src/x402/index.d.ts"],
      "*": ["./dist/esm/src/index.d.ts"]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/esm/src/index.d.ts",
      "import": {
        "types": "./dist/esm/src/index.d.ts",
        "default": "./dist/esm/src/index.js"
      },
      "require": {
        "types": "./dist/esm/src/index.d.cts",
        "default": "./dist/cjs/src/index.cjs"
      }
    },
    "./x402": {
      "types": "./dist/esm/src/x402/index.d.ts",
      "import": {
        "types": "./dist/esm/src/x402/index.d.ts",
        "default": "./dist/esm/src/x402/index.js"
      },
      "require": {
        "types": "./dist/esm/src/x402/index.d.cts",
        "default": "./dist/cjs/src/x402/index.cjs"
      }
    },
    "./events": {
      "types": "./dist/esm/src/events/index.d.ts",
      "import": {
        "types": "./dist/esm/src/events/index.d.ts",
        "default": "./dist/esm/src/events/index.js"
      },
      "require": {
        "types": "./dist/esm/src/events/index.d.cts",
        "default": "./dist/cjs/src/events/index.cjs"
      }
    },
    "./browser": {
      "types": "./dist/esm/src/browser/index.d.ts",
      "import": {
        "types": "./dist/esm/src/browser/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/esm/src/browser/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./idl/vela_protocol.json": "./idl/vela_protocol.json"
  },
  "bin": {
    "vela": "./bin/vela"
  },
  "files": ["dist", "bin", "cli", "idl"],
  "scripts": {
    "build": "bun run build.ts",
    "prepublishOnly": "bun run release:verify",
    "test": "bun test",
    "test:protocol": "bun run ./scripts/assert-protocol-artifacts.ts && bun test tests/unit/idl.test.ts tests/integration/client.test.ts tests/integration/simulate.test.ts tests/integration/emergency.test.ts tests/integration/agent-mandate-client.test.ts --reporter=dot",
    "check": "tsc --noEmit",
    "release:verify": "bun run check && bun test && bun run test:protocol && bun run build && bun run smoke:package",
    "smoke:package": "bun run ./scripts/release-smoke.ts",
    "lint": "bunx @biomejs/biome check src/ cli/ tests/ scripts/",
    "format": "bunx @biomejs/biome format --write src/ cli/ tests/ scripts/"
  },
  "dependencies": {
    "@arcium-hq/client": "0.9.3",
    "@coral-xyz/anchor": "0.32.1",
    "@noble/hashes": "^2.0.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@x402/core": "^2.9.0",
    "@x402/fetch": "^2.9.0",
    "@x402/hono": "^2.9.0",
    "@x402/svm": "^2.9.0",
    "commander": "^14.0.3",
    "decimal.js": "10.6.0",
    "hono": "^4.12.12",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@types/bn.js": "^5.2.0",
    "@types/bun": "^1.3.3",
    "anchor-litesvm": "0.2.1",
    "fast-check": "4.6.0",
    "helius-sdk": "^2.2.2",
    "litesvm": "0.6.0",
    "typescript": "^5.8.0"
  },
  "peerDependencies": {
    "helius-sdk": "^2.2.2"
  },
  "peerDependenciesMeta": {
    "helius-sdk": {
      "optional": true
    }
  }
}
