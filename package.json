{
  "name": "@vela/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Vela subscription billing protocol on Solana",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vela-labs/vela-sdk.git"
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./x402": {
      "import": {
        "types": "./dist/esm/x402/index.d.ts",
        "default": "./dist/esm/x402/index.js"
      },
      "require": {
        "types": "./dist/esm/x402/index.d.ts",
        "default": "./dist/cjs/x402/index.cjs"
      }
    },
    "./idl/vela_protocol.json": "./idl/vela_protocol.json"
  },
  "bin": {
    "vela": "./bin/vela"
  },
  "files": ["dist", "bin", "cli", "idl"],
  "scripts": {
    "build": "bun run build.ts",
    "test": "bun test",
    "check": "tsc --noEmit",
    "lint": "bunx @biomejs/biome check src/ cli/ tests/",
    "format": "bunx @biomejs/biome format --write src/ cli/ tests/"
  },
  "dependencies": {
    "@arcium-hq/client": "0.9.3",
    "@coral-xyz/anchor": "0.32.1",
    "@noble/hashes": "^2.0.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@x402/core": "^2.9.0",
    "@x402/fetch": "^2.9.0",
    "@x402/hono": "^2.9.0",
    "@x402/svm": "^2.9.0",
    "commander": "^14.0.3",
    "hono": "^4.12.12"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "@biomejs/biome": "latest",
    "@types/bun": "^1.3.3",
    "@types/bn.js": "^5.2.0",
    "helius-sdk": "^2.2.2",
    "litesvm": "0.6.0",
    "anchor-litesvm": "0.2.1"
  },
  "peerDependencies": {
    "helius-sdk": "^2.2.2"
  },
  "peerDependenciesMeta": {
    "helius-sdk": {
      "optional": true
    }
  }
}
