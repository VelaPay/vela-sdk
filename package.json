{
  "name": "@velapay/sdk",
  "version": "0.2.0",
  "description": "TypeScript SDK for Vela — private, programmable payment authority on Solana",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vela-labs/vela-sdk.git"
  },
  "homepage": "https://velapay.com",
  "bugs": {
    "url": "https://github.com/vela-labs/vela-sdk/issues"
  },
  "keywords": [
    "solana",
    "subscription",
    "billing",
    "payments",
    "recurring",
    "web3",
    "blockchain",
    "token-2022",
    "transfer-hook",
    "vela"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/cjs/src/index.cjs",
  "module": "./dist/esm/src/index.js",
  "exports": {
    ".": {
      "bun": "./dist/esm/src/index.js",
      "import": "./dist/esm/src/index.js",
      "require": "./dist/cjs/src/index.cjs",
      "default": "./dist/esm/src/index.js"
    },
    "./accounts": {
      "bun": "./dist/esm/src/accounts/index.js",
      "import": "./dist/esm/src/accounts/index.js",
      "require": "./dist/cjs/src/accounts/index.cjs",
      "default": "./dist/esm/src/accounts/index.js"
    },
    "./errors": {
      "bun": "./dist/esm/src/errors/index.js",
      "import": "./dist/esm/src/errors/index.js",
      "require": "./dist/cjs/src/errors/index.cjs",
      "default": "./dist/esm/src/errors/index.js"
    },
    "./x402": {
      "bun": "./dist/esm/src/x402/index.js",
      "import": "./dist/esm/src/x402/index.js",
      "require": "./dist/cjs/src/x402/index.cjs",
      "default": "./dist/esm/src/x402/index.js"
    },
    "./events": {
      "bun": "./dist/esm/src/events/index.js",
      "import": "./dist/esm/src/events/index.js",
      "require": "./dist/cjs/src/events/index.cjs",
      "default": "./dist/esm/src/events/index.js"
    },
    "./inspection": {
      "bun": "./dist/esm/src/inspection/index.js",
      "import": "./dist/esm/src/inspection/index.js",
      "require": "./dist/cjs/src/inspection/index.cjs",
      "default": "./dist/esm/src/inspection/index.js"
    },
    "./instructions": {
      "bun": "./dist/esm/src/instructions/index.js",
      "import": "./dist/esm/src/instructions/index.js",
      "require": "./dist/cjs/src/instructions/index.cjs",
      "default": "./dist/esm/src/instructions/index.js"
    },
    "./protocol": {
      "bun": "./dist/esm/src/protocol/index.js",
      "import": "./dist/esm/src/protocol/index.js",
      "require": "./dist/cjs/src/protocol/index.cjs",
      "default": "./dist/esm/src/protocol/index.js"
    },
    "./security": {
      "bun": "./dist/esm/src/security/index.js",
      "import": "./dist/esm/src/security/index.js",
      "require": "./dist/cjs/src/security/index.cjs",
      "default": "./dist/esm/src/security/index.js"
    },
    "./token": {
      "bun": "./dist/esm/src/token/index.js",
      "import": "./dist/esm/src/token/index.js",
      "require": "./dist/cjs/src/token/index.cjs",
      "default": "./dist/esm/src/token/index.js"
    },
    "./browser": {
      "bun": "./dist/esm/index.js",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.js"
    },
    "./idl/vela_protocol.json": "./idl/vela_protocol.json"
  },
  "bin": {
    "vela": "bin/vela"
  },
  "files": [
    "dist",
    "bin",
    "idl",
    "docs",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "bun run build.ts",
    "prepublishOnly": "bun run release:verify",
    "test": "bun test",
    "test:protocol": "bun run ./scripts/assert-protocol-artifacts.ts && bun test tests/unit/idl.test.ts tests/integration/client.test.ts tests/integration/simulate.test.ts tests/integration/emergency.test.ts tests/integration/agent-mandate-client.test.ts --reporter=dot",
    "check": "tsc --noEmit",
    "release:preflight": "bun run ./scripts/release-preflight.ts",
    "release:verify": "bun run release:preflight && bun run check && bun test && bun run test:protocol && bun run build && bun run smoke:package",
    "smoke:package": "bun run ./scripts/release-smoke.ts",
    "docs:api": "bun run ./scripts/generate-api-docs.ts",
    "lint": "bunx @biomejs/biome check src/ cli/ tests/ scripts/",
    "format": "bunx @biomejs/biome format --write src/ cli/ tests/ scripts/"
  },
  "dependencies": {
    "@arcium-hq/client": "0.9.7",
    "@coral-xyz/anchor": "0.32.1",
    "@noble/hashes": "^2.0.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "commander": "^14.0.3",
    "hono": "^4.12.18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@types/bn.js": "^5.2.0",
    "@types/bun": "^1.3.3",
    "anchor-litesvm": "0.2.1",
    "bs58": "^6.0.0",
    "fast-check": "4.6.0",
    "helius-sdk": "^2.2.2",
    "litesvm": "0.6.0",
    "typescript": "^5.8.0"
  },
  "peerDependencies": {
    "helius-sdk": "^2.2.2"
  },
  "peerDependenciesMeta": {
    "helius-sdk": {
      "optional": true
    }
  }
}
